---
import { Time } from "../ui/time";
import { Separator } from "../ui/separator";
import { Card, CardContent } from "../ui/card";
---

<Card class="order-11 row-span-2 lg:order-5">
  <CardContent class="h-full flex flex-col items-center justify-around">
    <div>
      <p class="uppercase text-[0.6rem] tracking-wide text-center">My Time</p>
      <Time timezone="Asia/Jakarta" client:load />
    </div>
    <Separator />
    <div>
      <p class="uppercase text-[0.6rem] tracking-wide text-center">Your Time</p>
      <Time client:load />
    </div>
  </CardContent>
</Card>