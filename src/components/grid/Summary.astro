---
import { Card, CardContent, CardHeader, CardRedirect, CardTitle } from "../ui/card";
---

<Card class="
  order-1 row-span-5 bg-[url(/frieren.png)] bg-no-repeat bg-size-[150px_auto] bg-position-[right_5%_bottom_-80%]
  md:order-1 md:col-span-3 md:row-span-4 
  lg:bg-position-[right_10%_bottom_-50%]"
>
  <CardHeader>
    <CardTitle>Hello!</CardTitle>
  </CardHeader>
  <CardContent class="grid md:grid-cols-3">
    <div class="col-span-2 space-y-6 text-base">
      <p class="leading-5 [&:not(:first-child)]:mt-6">
        Hi there! I'm <span class="font-semibold">Vincen</span>. I recently graduated with a degree in Computer Science and a minor in Artificial Intelligence.
      </p>
      <p class="leading-5 [&:not(:first-child)]:mt-6">
        I am a full-stack web developer with a strong focus on backend engineering, specializing in building robust applications with Laravel.
      </p>
      <p class="leading-5 [&:not(:first-child)]:mt-6">
        Throughout my university journey, I gained valuable, hands-on industry experience through multiple software engineering internships.
      </p>
      <p class="text-base leading-5 [&:not(:first-child)]:mt-6">
        When I'm offline, you can usually find me tinkering with my mini home server or unwinding with some games.
      </p>

      <div class="flex gap-4">
        <CardRedirect 
          href="https://www.linkedin.com/in/vincen-dev/" 
          class="w-20 items-center ring-[#FF91A4] shadow-[4px_4px_0px_0px_var(--card),8px_8px_0px_0px_#FF91A4]"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="2em" height="2em" viewBox="0 0 24 24">
            <path d="M0 0h24v24H0z" fill="none"></path>
            <path fill="currentColor" d="M19 3a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2zm-.5 15.5v-5.3a3.26 3.26 0 0 0-3.26-3.26c-.85 0-1.84.52-2.32 1.3v-1.11h-2.79v8.37h2.79v-4.93c0-.77.62-1.4 1.39-1.4a1.4 1.4 0 0 1 1.4 1.4v4.93zM6.88 8.56a1.68 1.68 0 0 0 1.68-1.68c0-.93-.75-1.69-1.68-1.69a1.69 1.69 0 0 0-1.69 1.69c0 .93.76 1.68 1.69 1.68m1.39 9.94v-8.37H5.5v8.37z"></path>
          </svg>
        </CardRedirect>
        <CardRedirect 
          href="https://github.com/IdjiotSandwiches/" 
          class="w-20 items-center ring-[#FF91A4] shadow-[4px_4px_0px_0px_var(--card),8px_8px_0px_0px_#FF91A4]"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="2em" height="2em" viewBox="0 0 24 24">
            <path d="M0 0h24v24H0z" fill="none" />
            <path fill="currentColor" d="M12 2A10 10 0 0 0 2 12c0 4.42 2.87 8.17 6.84 9.5c.5.08.66-.23.66-.5v-1.69c-2.77.6-3.36-1.34-3.36-1.34c-.46-1.16-1.11-1.47-1.11-1.47c-.91-.62.07-.6.07-.6c1 .07 1.53 1.03 1.53 1.03c.87 1.52 2.34 1.07 2.91.83c.09-.65.35-1.09.63-1.34c-2.22-.25-4.55-1.11-4.55-4.92c0-1.11.38-2 1.03-2.71c-.1-.25-.45-1.29.1-2.64c0 0 .84-.27 2.75 1.02c.79-.22 1.65-.33 2.5-.33s1.71.11 2.5.33c1.91-1.29 2.75-1.02 2.75-1.02c.55 1.35.2 2.39.1 2.64c.65.71 1.03 1.6 1.03 2.71c0 3.82-2.34 4.66-4.57 4.91c.36.31.69.92.69 1.85V21c0 .27.16.59.67.5C19.14 20.16 22 16.42 22 12A10 10 0 0 0 12 2" />
          </svg>
        </CardRedirect>
      </div>
    </div>
  </CardContent>
</Card>
