---
import { Badge } from "../ui/badge";
import { Card, CardContent, CardHeader, CardTitle } from "../ui/card";
---

<Card class="order-3 row-span-2 md:order-7 lg:order-3">
  <CardHeader>
    <CardTitle>Frontend</CardTitle>
  </CardHeader>
  <CardContent class="space-x-1 space-y-1">
    <Badge variant="outline">HTML</Badge>
    <Badge variant="outline">CSS</Badge>
    <Badge variant="outline">Bootstrap</Badge>
    <Badge variant="outline">Tailwind CSS</Badge>
    <Badge variant="outline">JavaScript</Badge>
    <Badge variant="outline">React</Badge>
    <Badge variant="outline">Vue</Badge>
    <Badge variant="outline">InertiaJS</Badge>
    <Badge variant="outline">Blazor (Radzen)</Badge>
  </CardContent>
</Card>
