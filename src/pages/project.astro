---
import Layout from "@/layouts/Layout.astro";
import { GlobeCheck } from "@lucide/astro";
import { Badge } from "@/components/ui/badge";
import { BackButton } from "@/components/ui/button";
import { Card, CardContent, CardFooter, CardHeader, CardRedirect, CardTitle } from "@/components/ui/card";
import { ImageDialog } from "@/components/ui/custom";

const proj = [
  {
    title: 'Portfolio',
    stacks: [
      'Astro',
      'Vue',
      'Tailwind',
    ],
    desc: 'My personal portfolio website.',
    redirect: {
      github: 'https://github.com/IdjiotSandwiches/portfolio.git',
      demo: '/'
    },
    img: null
  },
  {
    title: 'GTA Vehicles Tracker',
    stacks: [
      'Laravel',
      'PHP',
      'Vue',
      'Tailwind',
      'MariaDB',
    ],
    desc: 'A website for tracking my vehicles in GTA Online.',
    redirect: {
      github: 'https://github.com/IdjiotSandwiches/gta-tracker.git',
    },
    img: null
  },
  {
    title: 'Gudang2Go',
    stacks: [
      '.NET 9.0',
      'C#',
      'Blazor',
      'Radzen',
      'SQL Server'
    ],
    desc: "Owned the UI layout for the company website and engineered the core settings & sync features for Gudang2Go's internal website.",
    redirect: {},
    img: [
      '/g2g-1.webp',
      '/g2g-2.webp',
      '/g2g-3.webp',
      '/g2g-4.webp',
    ]
  },
  {
    title: 'Loan Prediction using Machine Learning',
    stacks: [
      'Streamlit',
      'Python',
    ],
    desc: 'Machine learning model predicting loan approval ratings, developed as a final project for an ML course.',
    redirect: {
      github: 'https://github.com/IdjiotSandwiches/loan-prediction-ml.git',
      demo: 'https://german-loan-la01.streamlit.app/'
    },
    img: null
  },
  {
    title: 'PISN',
    stacks: [
      'Laravel',
      'PHP',
      'Bootstrap',
      'JQuery',
      'MySQL',
    ],
    desc: 'Built the administrative dashboard end-to-end as part of a BINUS IT Division SSG-9 project.',
    redirect: {
      demo: 'https://pisn.kemdiktisaintek.go.id/'
    },
    img: [
      '/pisn-1.webp',
      '/pisn-2.webp',
    ]
  },
  {
    title: 'Mini HRMS Rebuild',
    stacks: [
      'Laravel',
      'PHP',
      'Vue',
      'InertiaJS',
      'Tailwind',
      'Flowbite',
      'Blade',
      'JQuery',
      'MariaDB',
    ],
    desc: 'Comprehensive Laravel learning project. Updated using InertiaJS & Vue.',
    redirect: {
      github: 'https://github.com/IdjiotSandwiches/mini-hrms-rebuild.git',
      demo: 'https://mini-hrms.idjiot-sandwiches.my.id/'
    },
    img: null
  },
  {
    title: 'Simple Turn-Based Game',
    stacks: [
      'Java'
    ],
    desc: 'A simple turn-based game I developed while studying Java in University.',
    redirect: {
      github: 'https://github.com/IdjiotSandwiches/simple-turn-based.git'
    },
    img: null
  }, 
  {
    title: 'WatcHGoods',
    stacks: [
      'HTML',
      'CSS',
      'JavaScript'
    ],
    desc: 'Web-based final project developed for a Human-Computer Interaction (HCI) course.',
    redirect: {
      github: 'https://github.com/IdjiotSandwiches/watch-goods.git',
      demo: 'https://watch-goods-kappa.vercel.app/'
    },
    img: null
  },
];
---

<Layout>
  <main class="mx-auto flex w-full max-w-4xl flex-1 flex-col gap-4 rounded-xl p-4">
    <BackButton />
    <h2 class="scroll-m-20 pt-4 text-3xl font-semibold tracking-tight transition-colors first:mt-0">
      Projects
    </h2>
    <div class="grid md:grid-cols-2 gap-6">
      {proj.map(p => (
        <Card class="min-h-56">
          <CardHeader>
            <CardTitle>{p.title}</CardTitle>
            <div class="flex flex-wrap gap-2">
              {p.stacks.map(s => (
                <Badge variant="outline">{s}</Badge>
              ))}
            </div>
          </CardHeader>
          <CardContent>
            <p class="text-base">{p.desc}</p>
          </CardContent>
          <CardFooter class="gap-4 mt-auto pb-4">
            {Object.entries(p.redirect).map(
              ([key, value]) => (
                <CardRedirect 
                  href={value}
                  target="_blank"
                  class="ring-[#FF91A4] shadow-[4px_4px_0px_0px_var(--card),8px_8px_0px_0px_#FF91A4] p-0 m-0 w-fit"
                  aria-label={key}
                >
                  <CardContent class="flex items-center gap-2 py-2 px-3">
                    {key === 'github' && (
                      <>
                        <svg xmlns="http://www.w3.org/2000/svg" width="1.5em" height="1.5em" viewBox="0 0 24 24">
                          <path d="M0 0h24v24H0z" fill="none" />
                          <path fill="currentColor" d="M12 2A10 10 0 0 0 2 12c0 4.42 2.87 8.17 6.84 9.5c.5.08.66-.23.66-.5v-1.69c-2.77.6-3.36-1.34-3.36-1.34c-.46-1.16-1.11-1.47-1.11-1.47c-.91-.62.07-.6.07-.6c1 .07 1.53 1.03 1.53 1.03c.87 1.52 2.34 1.07 2.91.83c.09-.65.35-1.09.63-1.34c-2.22-.25-4.55-1.11-4.55-4.92c0-1.11.38-2 1.03-2.71c-.1-.25-.45-1.29.1-2.64c0 0 .84-.27 2.75 1.02c.79-.22 1.65-.33 2.5-.33s1.71.11 2.5.33c1.91-1.29 2.75-1.02 2.75-1.02c.55 1.35.2 2.39.1 2.64c.65.71 1.03 1.6 1.03 2.71c0 3.82-2.34 4.66-4.57 4.91c.36.31.69.92.69 1.85V21c0 .27.16.59.67.5C19.14 20.16 22 16.42 22 12A10 10 0 0 0 12 2" />
                        </svg>
                        <p class="scroll-m-20 text-base font-semibold tracking-tight">GitHub</p>
                      </>
                    )}
                    {key === 'demo' && (
                      <>
                        <GlobeCheck />
                        <p class="scroll-m-20 text-base font-semibold tracking-tight">Demo</p>
                      </>
                    )}                       
                  </CardContent>
                </CardRedirect>
              )
            )}
            {p.img && <ImageDialog client:load images={p.img} />}
          </CardFooter>
        </Card>
      ))}
    </div>
  </main>
</Layout>